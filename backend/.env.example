APP_NAME=Aevra
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=sqlite:///./aevra.db

JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=43200

CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

STORAGE_ROOT=./storage

# --- Local AI (Phase 2) ---
# Install Ollama separately from https://ollama.com, then run:
#   ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
AI_ENRICHMENT_ENABLED=true

CHROMA_PERSIST_DIR=./storage/chroma

# --- Media (Phase 3) ---
# Whisper model: "tiny"|"base"|"small"|"medium"|"large-v3" (bigger = more
# accurate, slower, more RAM). Downloads from Hugging Face on first use.
WHISPER_MODEL_SIZE=small

# Piper voice: auto-downloads from Hugging Face on first narration request.
# If that fails (no internet), download manually -- see backend/README.md.
PIPER_VOICES_DIR=./storage/voices
PIPER_DEFAULT_VOICE=en_US-lessac-medium
